// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

// ─── Multi-Tenant ─────────────────────────────────────────────────────────────

model Tenant {
    id        String   @id @default(cuid())
    name      String
    createdAt DateTime @default(now())

    users                  User[]
    clientes               Cliente[]
    boletos                Boleto[]
    lancamentos            Lancamento[]
    configuracoesBancarias ConfiguracaoBancaria[]
    despesas               Despesa[]
}

// ─── Autenticação ─────────────────────────────────────────────────────────────

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String    @unique
    passwordHash  String
    role          String    @default("FINANCEIRO")
    tenantId      String
    ativo         Boolean   @default(true)
    tenant        Tenant    @relation(fields: [tenantId], references: [id])
    createdAt     DateTime  @default(now())

    // Mantidos para compatibilidade com PrismaAdapter (OAuth / sessões futuras)
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]

    @@index([tenantId])
}

// ─── NextAuth — Adapter tables (mantidas para compatibilidade) ────────────────

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    refresh_token_expires_in Int?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── Clientes ─────────────────────────────────────────────────────────────

model Cliente {
    id        String   @id @default(cuid())
    tenantId  String
    tenant    Tenant   @relation(fields: [tenantId], references: [id])
    nome      String
    cpfCnpj   String?
    email     String?
    telefone  String?
    ativo     Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    boletos     Boleto[]
    lancamentos Lancamento[]

    @@index([tenantId])
}

// ─── Boletos ─────────────────────────────────────────────────────────────

model Boleto {
    id            String   @id @default(cuid())
    tenantId      String
    tenant        Tenant   @relation(fields: [tenantId], references: [id])
    clienteId     String
    cliente       Cliente  @relation(fields: [clienteId], references: [id])
    
    nossoNumero   String
    valor         Decimal
    vencimento    DateTime
    banco         String   // SICOOB, ITAU
    status        String   @default("PENDENTE") // PENDENTE, REGISTRADO, PAGO, VENCIDO, OCORRENCIA, CANCELADO
    descricao     String?
    parcela       Int?
    totalParcelas Int?
    
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@unique([tenantId, nossoNumero])
    @@index([tenantId])
    @@index([nossoNumero])
}

// ─── Configuração Bancária ─────────────────────────────────────────────────────────────

model ConfiguracaoBancaria {
    id                 String   @id @default(cuid())
    tenantId           String
    tenant             Tenant   @relation(fields: [tenantId], references: [id])
    
    banco              String   // SICOOB, ITAU
    agencia            String?
    conta              String?
    convenio           String?
    nossoNumeroInicial Int      @default(1)
    nossoNumeroAtual   Int      @default(1)
    
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    @@unique([tenantId, banco])
    @@index([tenantId])
}

// ─── Lançamentos Manuais ─────────────────────────────────────────────────────────────

model Lancamento {
    id            String    @id @default(cuid())
    tenantId      String
    tenant        Tenant    @relation(fields: [tenantId], references: [id])
    clienteId     String
    cliente       Cliente   @relation(fields: [clienteId], references: [id])
    
    valor         Decimal
    vencimento    DateTime
    metodo        String    // PIX, TED, DOC, DINHEIRO, CHEQUE
    status        String    @default("PENDENTE") // PENDENTE, PAGO, CANCELADO
    descricao     String?
    dataPagamento DateTime?
    
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    @@index([tenantId])
    @@index([vencimento])
}

// ─── Despesas (Contas a Pagar) ──────────────────────────────────────────────────

model Despesa {
    id            String    @id @default(cuid())
    tenantId      String
    tenant        Tenant    @relation(fields: [tenantId], references: [id])
    
    descricao     String
    valor         Decimal
    vencimento    DateTime
    categoria     String
    status        String    @default("PENDENTE") // PENDENTE, PAGO, VENCIDO, CANCELADO
    dataPagamento DateTime?
    formaPagamento String?

    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    @@index([tenantId])
    @@index([vencimento])
}
